        <script><![CDATA[(function executeRule(current, previous /*null when async*/) {
	var partsTable = new GlideRecord('x_2103100_indust_0_spare_part');
	if (partsTable.get(current.spare_part)) {
		if(partsTable.quantity_in_stock < current.quantity_used) {
			gs.addErrorMessage('Not enough spare parts in stock');
			current.setAbortAction(true);
			return;
		}
		partsTable.quantity_in_stock = partsTable.quantity_in_stock - current.quantity_used;
		partsTable.update();
	}
})(current, previous);]]></script>
